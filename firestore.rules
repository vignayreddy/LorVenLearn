rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "vignaymuduganti2006@gmail.com" && request.auth.token.email_verified == true));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isInstructor() {
      return isAuthenticated() && (getUserData().role == 'instructor' || isAdmin());
    }
    
    function isStudent() {
      return isAuthenticated() && (getUserData().role == 'student' || isAdmin());
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && 
                      request.resource.data.role in ['student', 'instructor'] &&
                      request.resource.data.keys().hasAll(['uid', 'email', 'role', 'createdAt']);
      allow update: if isOwner(userId) && 
                      request.resource.data.role == resource.data.role; // Role cannot be changed
    }

    // Courses
    match /courses/{courseId} {
      allow read: if true; // Allow public read for browsing
      allow create: if (courseId == 'course_1' || courseId == 'course_2') || 
                      (isInstructor() && request.resource.data.instructorId == request.auth.uid);
      allow update: if isInstructor() && resource.data.instructorId == request.auth.uid;
      allow delete: if isInstructor() && resource.data.instructorId == request.auth.uid;
    }

    // Connection Test
    match /test/{docId} {
      allow read: if true;
    }

    // Enrollments
    match /enrollments/{enrollmentId} {
      allow read: if isAuthenticated() && 
                    (request.auth.uid == resource.data.studentId || isInstructor());
      allow create: if isStudent() && 
                      request.resource.data.studentId == request.auth.uid;
      allow delete: if isOwner(resource.data.studentId);
    }

    // Missing collections
    match /progress/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /certificates/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /announcements/{docId} {
      allow read: if true;
      allow write: if isInstructor();
    }
    match /notes/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /discussions/{docId} {
      allow read, write: if isAuthenticated();
    }
  }
}
