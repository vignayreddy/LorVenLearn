{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role (student or instructor)",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "role": { "type": "string", "enum": ["student", "instructor"], "description": "User's role in the system" },
        "displayName": { "type": "string", "description": "User's display name" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created" }
      },
      "required": ["uid", "email", "role"]
    },
    "Course": {
      "title": "Course",
      "description": "A course created by an instructor",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the course" },
        "title": { "type": "string", "description": "Course title" },
        "description": { "type": "string", "description": "Course description" },
        "price": { "type": "number", "description": "Course price" },
        "instructorId": { "type": "string", "description": "UID of the instructor who created the course" },
        "instructorName": { "type": "string", "description": "Name of the instructor" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the course was created" },
        "lessons": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "content": { "type": "string" },
              "videoUrl": { "type": "string" }
            }
          }
        }
      },
      "required": ["title", "instructorId"]
    },
    "Enrollment": {
      "title": "Enrollment",
      "description": "A student's enrollment in a course",
      "type": "object",
      "properties": {
        "studentId": { "type": "string", "description": "UID of the student" },
        "courseId": { "type": "string", "description": "ID of the course" },
        "enrolledAt": { "type": "string", "format": "date-time", "description": "When the student enrolled" }
      },
      "required": ["studentId", "courseId"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/courses/{courseId}": { "schema": "Course", "description": "Course data" },
    "/enrollments/{enrollmentId}": { "schema": "Enrollment", "description": "Enrollment records" }
  }
}
